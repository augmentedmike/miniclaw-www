{
  "name": "miniclaw",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "miniclaw": "./bin/miniclaw"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "serve": "PORT=3737 tsx src/index.ts serve",
    "dev": "lsof -ti:3737 | xargs kill -9 2>/dev/null; PORT=3737 tsx src/index.ts serve",
    "cli": "tsx src/index.ts --message",
    "setup": "tsx src/setup.ts",
    "vault": "tsx src/vault-cli.ts",
    "vault:init": "tsx src/vault-cli.ts init",
    "persona": "tsx src/persona-cli.ts",
    "snapshot": "tsx src/snapshot-cli.ts",
    "kb": "tsx src/kb-cli.ts",
    "import:am": "tsx scripts/import-am.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/",
    "test:e2e": "vitest run e2e/",
    "test:devtools": "vitest run devtools/",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage tests/",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:devtools": "tsc --noEmit -p tsconfig.devtools.json",
    "depgraph": "tsx devtools/depgraph.ts --root src/",
    "complexity": "tsx devtools/complexity.ts --root src/",
    "solid": "tsx devtools/solid-check.ts --root src/",
    "duplication": "tsx devtools/duplication.ts --root src/",
    "dead-code": "tsx devtools/dead-code.ts --root src/",
    "api-surface": "tsx devtools/api-surface.ts --root src/",
    "state-machine": "tsx devtools/state-machine.ts --root src/",
    "side-effects": "tsx devtools/side-effects.ts --root src/",
    "coupling": "tsx devtools/coupling.ts --root src/",
    "readability": "tsx devtools/readability.ts --root src/",
    "cohesion": "tsx devtools/cohesion.ts --root src/",
    "features": "tsx devtools/features.ts --root src/",
    "features:md": "tsx devtools/features.ts --root src/ --format markdown",
    "features:json": "tsx devtools/features.ts --root src/ --format json",
    "docs": "tsx devtools/docgen.ts --root src/ --out docs/",
    "docs:stdout": "tsx devtools/docgen.ts --root src/ --stdout",
    "report": "tsx devtools/report.ts --root src/ --out reports/",
    "hooks:install": "bash scripts/install-hooks.sh",
    "prepare": "bash scripts/install-hooks.sh 2>/dev/null || true",
    "audit": "npm run solid && npm run complexity && npm run coupling && npm run readability && npm run cohesion && npm run duplication && npm run dead-code",
    "build": "node build.mjs",
    "install:prod": "npm run build && bash install.sh",
    "install:dev": "npm run build && bash install.sh --dev"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0",
    "@clack/prompts": "^1.0.1",
    "@grammyjs/runner": "^2.0",
    "@grammyjs/transformer-throttler": "^1.2",
    "@huggingface/transformers": "^3.8.1",
    "ai": "^4.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.0",
    "grammy": "^1.40",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.27.3",
    "tsx": "^4.19",
    "typescript": "^5.7",
    "vitest": "^3.0"
  }
}
