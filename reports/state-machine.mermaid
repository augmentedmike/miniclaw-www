%% telegram/handlers.ts :: registerHandlers_flow
stateDiagram-v2
  [*] --> start
  state error <<error>>
  start --> ctx_answerCallbackQuery : await ctx.answerCallbackQuery()
  ctx_answerCallbackQuery --> ctx_answerCallbackQuery : await ctx.answerCallbackQuery()
  ctx_answerCallbackQuery --> ctx_editMessageText : await ctx.editMessageText()
  ctx_editMessageText --> bot_api_sendMessage : await bot.api.sendMessage()
  bot_api_sendMessage --> ctx_answerCallbackQuery : await ctx.answerCallbackQuery()
  ctx_answerCallbackQuery --> ctx_editMessageText : await ctx.editMessageText()
  ctx_editMessageText --> bot_api_sendMessage : await bot.api.sendMessage()
  bot_api_sendMessage --> bot_api_sendMessage : await bot.api.sendMessage()
  bot_api_sendMessage --> bot_api_sendMessage : await bot.api.sendMessage()
  bot_api_sendMessage --> bot_api_sendMessage : await bot.api.sendMessage()
  bot_api_sendMessage --> runAgent : await runAgent()
  runAgent --> sendResponse : await sendResponse()
  sendResponse --> bot_api_sendMessage : await bot.api.sendMessage()
  bot_api_sendMessage --> bot_api_sendMessage : await bot.api.sendMessage()
  bot_api_sendMessage --> error : catch
  bot_api_sendMessage --> complete : return
  complete --> [*]

