{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"],
      "@tools/*": ["src/tools/*"],
      "@telegram/*": ["src/telegram/*"],
      "@memory/*": ["src/memory/*"],
      "@web/*": ["src/web/*"],
      "@kb/*": ["src/kb/*"]
    }
  }
}
